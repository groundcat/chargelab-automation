# Copy to .env and fill in real values. Never commit .env.

# Webhook server
WEBHOOK_PORT=80
WEBHOOK_SECRET=change-me-to-a-long-random-string

# ChargeID / EVStart
CHARGEID_BASE_URL=https://charge.id/
CHARGEID_LOGIN_EMAIL=you@example.com
CHARGEID_CHARGER_ID=evs-0000

# Mailbox used for both receiving the login code (IMAP) and
# sending result notifications (SMTP). Usually the same address
# as CHARGEID_LOGIN_EMAIL.
LOGIN_EMAIL_HOST=mail.example.com
LOGIN_EMAIL_USERNAME=you@example.com
LOGIN_EMAIL=you@example.com
LOGIN_EMAIL_PASSWORD=your-mailbox-password
LOGIN_EMAIL_SECURE_IMAP_PORT=993
LOGIN_EMAIL_SECURE_SMTP_PORT=587

# Timestamps in result emails
TIMEZONE=America/Toronto

# Optional: where the reusable browser login session is stored.
# Default is /data/browser_state.json (a Docker volume in the compose setup),
# so subsequent runs skip the email-code login while the session is valid.
#BROWSER_STATE_PATH=/data/browser_state.json
